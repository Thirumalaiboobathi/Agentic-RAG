# .env.example — copy to .env and fill in real values
# ----------------------------------------------------
# For LOCAL testing. In ECS, these come from the task definition
# (plain values) and Secrets Manager (secrets).

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── Bedrock model + credentials ───────────────────────────────────────────────
# Model ID: use inference profile prefix for cross-region routing (us.*)
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
# Optional: set one of these to override the default credential chain
# ── Bedrock ─────────────────────────────────────────────────────
# Optional: named profile for Bedrock (local dev only, ignored in ECS).
BEDROCK_AWS_PROFILE=your-aws-profile
BEDROCK_AWS_ACCESS_KEY_ID=your-bedrock-access-key-id
BEDROCK_AWS_SECRET_ACCESS_KEY=your-bedrock-secret-access-key

# ── OpenSearch (same values as RAG_AWS/.env) ─────────────────────────────────
OPENSEARCH_HOST=https://search-your-domain.us-east-1.es.amazonaws.com
OPENSEARCH_INDEX_NAME=rag-vector-index
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=your-opensearch-password
USE_AWS_OPENSEARCH=false

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# For local docker-compose, these are overridden to point at the local container.
# For local-without-docker, point at your RDS endpoint.
POSTGRES_HOST=your-rds-endpoint.xxxx.us-east-1.rds.amazonaws.com
POSTGRES_DB=agentdb
POSTGRES_USER=agent
POSTGRES_PASSWORD=your-password-here

# ── Google Custom Search API ─────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CSE_ID=your-custom-search-engine-id
