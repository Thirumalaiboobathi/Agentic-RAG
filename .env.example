# .env.example — copy to .env and fill in real values
# ----------------------------------------------------
# For LOCAL testing. In ECS, these come from the task definition
# (plain values) and Secrets Manager (secrets).

# ── AWS credentials (local dev only) ─────────────────────────────────────────
# In ECS the task role provides credentials automatically — do NOT set these there.
# Locally, either use `aws configure` (reads ~/.aws/credentials) OR set these vars.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SESSION_TOKEN=                        # leave blank unless using temporary credentials

# ── AWS region ───────────────────────────────────────────────────────────────
# Used by boto3 (Bedrock + OpenSearch SigV4). The Bedrock model region is also
# set in config/agents.yaml under llm.region — keep both in sync.
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1             # boto3 reads this env var for the default region

# ── OpenSearch (reuse existing RAG pipeline domain) ──────────────────────────
OPENSEARCH_HOST=https://search-rag-vector-domain-xxx.us-east-1.es.amazonaws.com

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# For local docker-compose, these are overridden to point at the local container.
# For local-without-docker, point at your RDS endpoint.
POSTGRES_HOST=your-rds-endpoint.xxxx.us-east-1.rds.amazonaws.com
POSTGRES_DB=agentdb
POSTGRES_USER=agent
POSTGRES_PASSWORD=your-password-here

# ── Google Custom Search API ─────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CSE_ID=your-custom-search-engine-id
